{
  "name": "Export pointclouds project in Supervisely format",
  "type": "app",
  "categories": [
    "pointclouds",
    "export"
  ],
  "description": "Export pointclouds project and prepares downloadable tar archive",
  "docker_image": "supervisely/base-py-sdk:6.73.577",
  "instance_version": "6.16.19",
  "main_script": "src/main.py",
  "modal_template": "src/modal.html",
  "modal_template_state": {
    "items": "True"
  },
  "task_location": "workspace_tasks",
  "isolate": true,
  "headless": true,
  "icon": "https://github.com/supervisely-ecosystem/export-pointclouds-project-in-supervisely-format/releases/download/v1.1.8/icon-export-pcd.jpg",
  "icon_cover": true,
  "icon_background": "#FFFFFF",
  "context_menu": {
    "target": [
      "point_cloud_project"
    ],
    "context_root": "Download as"
  },
  "poster": "https://github.com/supervisely-ecosystem/export-pointclouds-project-in-supervisely-format/releases/download/v1.1.8/poster-export-pcd.jpg"
}
